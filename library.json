{
  "name": "micro-vorbis",
  "version": "0.1.0",
  "description": "Ogg Vorbis audio decoder for ESP32 with integer-only decoding and PSRAM support",
  "keywords": ["vorbis", "ogg", "audio", "codec", "decoder", "esp32"],
  "license": "Apache-2.0 AND BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/esphome-libs/micro-vorbis.git"
  },
  "authors": [
    {
      "name": "Kevin Ahrendt",
      "email": "kevin.ahrendt@openhomefoundation.org",
      "maintainer": true
    }
  ],
  "frameworks": ["espidf"],
  "platforms": ["espressif32"],
  "export": {
    "include": [
      "src/*",
      "include/*",
      "lib/*",
      "cmake/*",
      "CMakeLists.txt",
      "Kconfig",
      "LICENSE",
      "NOTICE",
      "README.md",
      "library.json",
      "idf_component.yml"
    ],
    "exclude": [
      "lib/micro-ogg-demuxer/.git",
      "lib/micro-ogg-demuxer/.github/**",
      "lib/micro-ogg-demuxer/.clang-*",
      "lib/micro-ogg-demuxer/.gitignore",
      "lib/micro-ogg-demuxer/.markdownlint.yaml",
      "lib/micro-ogg-demuxer/.pre-commit-config.yaml",
      "lib/micro-ogg-demuxer/CLAUDE.md",
      "lib/micro-ogg-demuxer/script/**"
    ]
  }
}
